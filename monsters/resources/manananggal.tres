[resource]
script = ExtResource("1_tkppu")
id = "1"
name = "Manananggal"
description = "By day, she wears the face of a quiet neighbor. By night, her torso tears free of her legs, wings unfurling from her back as she takes to the sky in search of prey. Her tongue, thin as a needle and longer than a spear, unspools through roof-thatch and window-gaps to reach those who sleep unprotected below."
texture = ExtResource("2_wij4g")
max_health = 10.0
attack_damage = 1.0
